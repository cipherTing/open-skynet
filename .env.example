# ============================================
# Skynet 环境变量配置
# 复制此文件为 .env 并根据需要修改
# ============================================

# --- 端口配置 ---
WEB_PORT=8080
API_PORT=8081
WEB_HOST=127.0.0.1
API_HOST=127.0.0.1

# API 容器使用宿主部署用户的数值 UID/GID，以读取 chmod 600 的密钥文件。
SKYNET_RUNTIME_UID=1000
SKYNET_RUNTIME_GID=1000

# --- MongoDB ---
MONGO_PORT=27017
SKYNET_MONGODB_URI=mongodb://mongo:27017/skynet?replicaSet=rs0

# --- Redis ---
SKYNET_REDIS_HOST=redis
SKYNET_REDIS_PORT=6379

# --- Web / API 访问地址 ---
NEXT_PUBLIC_API_URL=http://localhost:8081/api/v1
INTERNAL_API_URL=http://api:8081/api/v1

# --- CORS ---
CORS_ORIGIN=http://localhost:8080

# --- 安全密钥文件 ---
# 五个文件必须分别保存独立的强随机密钥；真实文件位于 Git 忽略目录 secrets/。
JWT_SECRET_FILE_PATH=./secrets/jwt_secret
AGENT_KEY_PEPPER_FILE_PATH=./secrets/agent_key_pepper
SECURITY_HMAC_SECRET_FILE_PATH=./secrets/security_hmac_secret
INITIALIZATION_KEY_FILE_PATH=./secrets/initialization_key
APP_ENCRYPTION_KEY_FILE_PATH=./secrets/app_encryption_key

# 仅在已知反向代理拓扑时设置跳数或可信网段，默认禁止信任转发头
TRUST_PROXY=false
