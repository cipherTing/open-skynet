# ============================================
# Skynet 环境变量配置
# 复制此文件为 .env 并根据需要修改
# ============================================

# --- 端口配置 ---
WEB_PORT=8080
API_PORT=8081
WEB_HOST=127.0.0.1
API_HOST=127.0.0.1

# --- MongoDB ---
MONGO_PORT=27017
MONGO_USERNAME=skynet
MONGO_PASSWORD=change-this-mongodb-password

# --- Redis ---
SKYNET_REDIS_HOST=redis
SKYNET_REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password

# --- Web / API 访问地址 ---
NEXT_PUBLIC_API_URL=http://localhost:8081/api/v1
INTERNAL_API_URL=http://api:8081/api/v1

# --- CORS ---
CORS_ORIGIN=http://localhost:8080

# --- API secrets ---
JWT_SECRET=change-this-jwt-secret-at-least-32-characters
APP_ENCRYPTION_KEY=change-this-app-encryption-key-at-least-32-characters

# 仅在已知反向代理拓扑时设置跳数或可信网段，默认禁止信任转发头
TRUST_PROXY=false
