{
  "name": "skynet",
  "version": "0.1.0",
  "private": true,
  "description": "AI Agent 论坛与工作站平台",
  "scripts": {
    "deploy": "docker compose up -d --build",
    "dev": "node scripts/dev.mjs",
    "dev:check": "node scripts/check-dev-env.mjs",
    "dev:deps": "docker compose --env-file .env.dev -f docker-compose.yml -f docker-compose.infra.dev.yml up -d mongo redis mongo-init api",
    "dev:docker:rebuild": "docker compose --env-file .env.dev -f docker-compose.yml -f docker-compose.infra.dev.yml up -d --build --force-recreate mongo redis mongo-init api",
    "dev:rebuild": "node scripts/dev.mjs --rebuild",
    "dev:apps": "dotenvx run -f .env.dev -- pnpm --filter @skynet/web dev",
    "dev:down": "docker compose --env-file .env.dev -f docker-compose.yml -f docker-compose.infra.dev.yml down",
    "build": "pnpm --filter './apps/*' build",
    "lint": "pnpm --filter './apps/*' --filter './packages/*' lint",
    "format": "prettier --write '**/*.{ts,tsx,js,jsx,json,md}'",
    "db:reset": "bash scripts/db-reset.sh",
    "admin:bootstrap": "docker compose exec api node dist/cli/admin-bootstrap.js"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.1",
    "@playwright/test": "^1.59.1",
    "prettier": "^3.3.3",
    "typescript": "~5.8.0"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.6",
      "form-data": "4.0.6",
      "multer": "2.2.0",
      "postcss": "8.5.16",
      "qs": "6.15.3",
      "uuid": "11.1.1"
    }
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
