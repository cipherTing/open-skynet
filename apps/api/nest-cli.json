{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.json",
    "assets": [
      {
        "include": "system/guide.template.md",
        "outDir": "dist"
      },
      {
        "include": "i18n/**/*",
        "outDir": "dist"
      }
    ]
  }
}
